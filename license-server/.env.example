# HP License Server — environment variables
# Copy file này sang `.env` và điền giá trị thật. KHÔNG commit `.env` lên git.

# Port server chạy (mặc định 8787)
PORT=8787

# Google Sheet chứa danh sách KEY
SHEET_ID=1Fv9Jdno_pPMTx_-tnwSfRObm1r1wKds_gaMBnfCDm4M
KEY_SHEET_NAME=KEY_HP_GAME

# Admin token — bảo vệ /admin endpoint. SINH NGẪU NHIÊN, KHÔNG dùng giá trị default.
# Sinh token mới (terminal):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Hoặc Linux: openssl rand -hex 32
ADMIN_TOKEN=CHANGE-ME-TO-RANDOM-64-HEX-STRING

# CORS origin cho phép (mặc định * — production nên giới hạn tới domain app)
CORS_ORIGIN=*

# Rate limit: số request tối đa mỗi IP trong 1 phút (chống brute force key)
RATE_LIMIT_PER_MIN=20

# Bật device binding (mỗi key chỉ dùng được trên N máy)
DEVICE_BIND_ENABLED=true
DEVICE_BIND_MAX=2

# Log file path
LOG_FILE=./data/activations.log
