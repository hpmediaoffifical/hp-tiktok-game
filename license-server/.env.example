# HP License Server — environment variables
# Copy file này sang `.env` và điền giá trị thật. KHÔNG commit `.env` lên git.

# Port server chạy (mặc định 8787)
PORT=8787

# Google Sheet chứa danh sách KEY
SHEET_ID=1Fv9Jdno_pPMTx_-tnwSfRObm1r1wKds_gaMBnfCDm4M
KEY_SHEET_NAME=KEY_HP_GAME

# Ed25519 private key (PEM PKCS8) để ký response
# Sinh bằng: node keygen.js
# Paste TOÀN BỘ nội dung private-key.pem vào đây (multiline, escape \n bằng cách thay newline thành \n
# hoặc dùng PEM tải từ file qua SIGN_PRIVATE_KEY_FILE)
SIGN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIBOImgURwONZqdhWMnjE04zVE3mdhTFdpch9hy8GDwOT\n-----END PRIVATE KEY-----"

# Hoặc đường dẫn file PEM (ưu tiên hơn SIGN_PRIVATE_KEY)
# SIGN_PRIVATE_KEY_FILE=./data/private-key.pem

# Admin token — bảo vệ /admin endpoint. SINH NGẪU NHIÊN, KHÔNG dùng giá trị default.
# Vd: openssl rand -hex 32
ADMIN_TOKEN=CHANGE-ME-TO-RANDOM-64-HEX-STRING

# CORS origin cho phép (mặc định * — production nên giới hạn)
CORS_ORIGIN=*

# Rate limit: số request tối đa mỗi IP trong 1 phút
RATE_LIMIT_PER_MIN=20

# Bật device binding (mỗi key chỉ dùng được trên N máy)
DEVICE_BIND_ENABLED=true
DEVICE_BIND_MAX=2

# Log file path
LOG_FILE=./data/activations.log
